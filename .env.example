# =============================================================================
#  Gestión Global · .env.example
# =============================================================================
#
#  Copia este archivo a .env.local y completá los valores SOLO del bloque
#  "Cliente (Vite)". Los secretos del bloque "Edge functions" NO van en el
#  repo: se cargan como Supabase secrets (Dashboard → Project Settings →
#  Edge Functions → Secrets).
#
#  Reglas no negociables (CLAUDE.md):
#    · Regla 3 — NUNCA exponer service_role, tokens OAuth ni VAPID privadas
#      con prefijo VITE_.
#    · Regla 6 — toda variable nueva consumida por una edge function debe
#      quedar listada acá con un comentario sobre su origen.
#
# =============================================================================

# -----------------------------------------------------------------------------
#  Cliente (Vite) — leído por el bundle estático servido por Vercel
# -----------------------------------------------------------------------------

# URL pública del proyecto Supabase (Dashboard → Project Settings → API).
VITE_SUPABASE_URL=

# Anon key pública (sólo válida bajo RLS). NO usar service_role acá.
VITE_SUPABASE_ANON_KEY=

# Cadena visible en el footer ("v...") para identificar el build en QA.
# Vercel inyecta automáticamente; en local se puede dejar vacío o usar 'dev'.
VITE_APP_VERSION=dev

# Entorno lógico ('development' | 'staging' | 'production'). Sólo
# decorativo; no afecta routing ni features.
VITE_ENV=development

# VAPID PUBLIC key para suscripciones Web Push (la matching PRIVATE va en
# Supabase secrets). Generar con:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# =============================================================================
#  Edge functions — NO commitear, cargar como Supabase secrets
#  (`supabase secrets set NAME=value`)
# =============================================================================

# -----------------------------------------------------------------------------
#  Supabase core
# -----------------------------------------------------------------------------
# Las primeras 3 son inyectadas automáticamente por Supabase en cada edge
# function — no hace falta setearlas a mano, pero listadas por trazabilidad.
#   SUPABASE_URL                  — auto
#   SUPABASE_ANON_KEY             — auto
#   SUPABASE_SERVICE_ROLE_KEY     — auto (bypassa RLS; usado por casi todas las fns)

# -----------------------------------------------------------------------------
#  Cron auth (pg_cron + pg_net → edge fns protegidas)
# -----------------------------------------------------------------------------
# Token compartido entre los jobs de pg_cron (header `X-Cron-Secret`) y las
# edge functions de dispatcher (dispatch-emails, dispatch-vencimientos,
# dispatch-push, cron-frase-del-dia, cron-webinar-recordatorios, etc.).
# Generar con `openssl rand -hex 32`.
#   CRON_SECRET

# -----------------------------------------------------------------------------
#  Email (Google Workspace SMTP + OAuth)
# -----------------------------------------------------------------------------
# Single-casilla legacy (compat con flows previos a multi-casilla):
#   WORKSPACE_SMTP_USER           — ej: contacto@gestionglobal.ar
#   WORKSPACE_SMTP_PASS           — App Password (16 chars sin espacios)
#   WORKSPACE_FROM_NAME           — default "Gestión Global"
#   WORKSPACE_REPLY_TO            — default = SMTP_USER

# OAuth 2.0 para envío como múltiples casillas (cursos@, juridico@, etc.):
#   GOOGLE_OAUTH_CLIENT_ID
#   GOOGLE_OAUTH_CLIENT_SECRET
#   GOOGLE_OAUTH_SENDER_EMAIL     — admin Workspace que firma los tokens
#   GOOGLE_OAUTH_REFRESH_TOKEN    — legacy / fallback
#   GMAIL_OAUTH_REFRESH_TOKEN_DEFAULT — casilla "general" para emails sin from_casilla
#   OAUTH_STATE_SECRET            — HMAC para state= en OAuth callback

# Por casilla adicional, setear refresh tokens dinámicos vía panel admin
# (DGG-22). El edge function `email-send` los lee de la tabla
# `email_oauth_tokens` (no de env vars).

# -----------------------------------------------------------------------------
#  Web Push (VAPID)
# -----------------------------------------------------------------------------
#   VAPID_PUBLIC_KEY              — mismo valor que VITE_VAPID_PUBLIC_KEY
#   VAPID_PRIVATE_KEY             — SECRETA
#   VAPID_SUBJECT                 — ej: mailto:soporte@gestionglobal.ar

# -----------------------------------------------------------------------------
#  Zoom (cursos en vivo y webinars · DGG-15 / DGG-16)
# -----------------------------------------------------------------------------
# Server-to-Server OAuth (para crear meetings vía API):
#   ZOOM_ACCOUNT_ID
#   ZOOM_S2S_CLIENT_ID
#   ZOOM_S2S_CLIENT_SECRET
# Meeting / Video SDK (para embed JWT):
#   ZOOM_SDK_KEY
#   ZOOM_SDK_SECRET
# Webhook entrante de eventos de meeting:
#   ZOOM_WEBHOOK_SECRET_TOKEN

# -----------------------------------------------------------------------------
#  Webex (proveedor alterno · DGG-19, plugin opcional)
# -----------------------------------------------------------------------------
# Guest Issuer (JWT para invitados):
#   WEBEX_GUEST_ISSUER_ID
#   WEBEX_GUEST_SHARED_SECRET
# Webhook entrante (verificación de firma):
#   WEBEX_WEBHOOK_SECRET

# =============================================================================
#  Frontend en Vercel
# =============================================================================
#  Las VITE_* van como Environment Variables en Vercel → Project → Settings.
#  Recordá marcarlas para los 3 entornos (Production / Preview / Development).
#
# =============================================================================
